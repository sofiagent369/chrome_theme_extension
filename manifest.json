{
  "manifest_version": 3,
  "name": "Chrome Theme Extension",
  "version": "1.0.0",
  "description": "Permite cambiar el tema/colores de cualquier página web.",
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"]
    }
  ],
  "permissions": [
    "storage",
    "activeTab"
  ]
}